# Obligatoire
DISCORD_TOKEN=
DISCORD_CLIENT_ID=

# MongoDB (Railway : variable MONGO_URL fournie par le plugin)
MONGO_URL=

# Optionnel : déployer les slash sur un seul serveur (recommandé)
GUILD_ID=

# Rôle « Gestion » pour /check et /podium (sinon utilise /config gestion-role sur le serveur)
GESTION_ROLE_ID=

# Rôles staff autorisés (IDs séparés par des virgules). Si vide : ManageGuild / Admin
STAFF_ROLE_IDS=

# Enregistrer les commandes slash à chaque démarrage (guild si GUILD_ID défini)
REGISTER_ON_START=true

# Couleur des embeds si non définie en /config (ex. 9b59b6 ou #9b59b6)
DEFAULT_EMBED_COLOR=9b59b6
